{
  "name": "beauty-shop-management",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "美妆店产品管理系统",
  "author": "Beauty Shop Team",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:prod": "vue-tsc --noEmit && vite build --mode production",
    "preview": "vite preview",
    "preview:build": "npm run build && vite preview",
    "typecheck": "vue-tsc --noEmit",
    "clean": "rimraf dist && rimraf node_modules/.vite"
  },
  "dependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue-tsc": "^1.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "beauty",
    "management",
    "inventory",
    "vue3"
  ]
}
