{
  "name": "flower-shop-management",
  "version": "1.0.0",
  "description": "小型花店花卉管理系统 - 基于React + TypeScript + Webpack",
  "author": "Flower Shop",
  "license": "MIT",
  "main": "src/index.tsx",
  "scripts": {
    "start": "webpack serve --mode development --open",
